import XMonad

import qualified XMonad.StackSet as W
import qualified Data.Map as M

import XMonad.Util.EZConfig
import XMonad.Util.SpawnOnce

import XMonad.Hooks.EwmhDesktops
import XMonad.Hooks.ManageDocks
import XMonad.Hooks.StatusBar
import XMonad.Hooks.StatusBar.PP

import XMonad.Layout.Spacing
import XMonad.Layout.NoBorders
import XMonad.Layout.ResizableTile

--------------------------------------------------
-- Kanagawa colors
--------------------------------------------------

colorBg       = "#1f1f28"
colorFg       = "#dcd7ba"
colorGray     = "#727169"
colorBlue     = "#7e9cd8"
colorMagenta  = "#957fb8"

--------------------------------------------------
-- Basic settings
--------------------------------------------------

myModMask = mod4Mask

myTerminal = "alacritty"

myBorderWidth = 2

myNormColor = colorGray

myFocusColor = colorBlue

--------------------------------------------------
-- Workspaces
--------------------------------------------------

myWorkspaces = map show [1..9]

--------------------------------------------------
-- GAPS (outer + inner always visible)
--------------------------------------------------

myGap = 4

mySpacing =
 spacingRaw
  False
  (Border myGap myGap myGap myGap)
  False
  (Border myGap myGap myGap myGap)
  True

--------------------------------------------------
-- Layouts
--------------------------------------------------

tall =
 mySpacing $
 ResizableTall
 1
 (3/100)
 (1/2)
 []

wide =
 mySpacing $
 Mirror $
 ResizableTall
 1
 (3/100)
 (1/2)
 []

full =
 noBorders Full

myLayout =
 avoidStruts
 (tall ||| wide ||| full)

--------------------------------------------------
-- Floating toggle
--------------------------------------------------

toggleFloat w =
 windows (\s ->
  if M.member w (W.floating s)
  then W.sink w s
  else W.float w
   (W.RationalRect 0.1 0.1 0.8 0.8)
   s)

--------------------------------------------------
-- Keybinds estilo i3
--------------------------------------------------

myKeys =

 [

 ("M-<Return>", spawn myTerminal)

 , ("M-d", spawn "rofi -show drun")

 , ("M-q", kill)

 , ("M-S-r",
 spawn "xmonad --recompile && xmonad --restart")

 , ("M-j", windows W.focusDown)

 , ("M-k", windows W.focusUp)

 , ("M-h", sendMessage Shrink)

 , ("M-l", sendMessage Expand)

 , ("M-S-j", windows W.swapDown)

 , ("M-S-k", windows W.swapUp)

 , ("M-<Space>", sendMessage NextLayout)

 , ("M-S-<Space>", withFocused toggleFloat)

 ]

 ++

 [

 ("M-" ++ show i,
 windows $ W.greedyView (show i))

 | i <- [1..9]

 ]

 ++

 [

 ("M-S-" ++ show i,
 windows $ W.shift (show i))

 | i <- [1..9]

 ]

--------------------------------------------------
-- Startup
--------------------------------------------------

myStartupHook = do

 spawnOnce "feh --bg-fill ~/walls/wallhaven-6l5wr6_3840x2160.png"

 spawnOnce "nm-applet"

 spawnOnce "volumeicon"

--------------------------------------------------
-- Config
--------------------------------------------------

myConfig =
 def

 {

 modMask = myModMask

 , terminal = myTerminal

 , borderWidth = myBorderWidth

 , normalBorderColor = myNormColor

 , focusedBorderColor = myFocusColor

 , workspaces = myWorkspaces

 , layoutHook = myLayout

 , startupHook = myStartupHook

 }

 `additionalKeysP` myKeys

--------------------------------------------------
-- Main
--------------------------------------------------

main =
 xmonad

 . ewmh

 . withEasySB
   (statusBarProp
    "xmobar ~/.config/xmobar/xmobarrc"
    (pure def))

   defToggleStrutsKey

 $ myConfig
